---
import { AvButton, AvDrawer } from "@ansiversa/components";

interface Props {
  title: string;
  description?: string;
  open?: boolean;
  onClose?: string;
}

const { title, description, open = true, onClose = "$store.appDrawer.close()" } = Astro.props as Props;
---

<div
  class="av-drawer-overlay"
  data-open={open ? "true" : "false"}
  @click.self={onClose}
  @keydown.escape.window={onClose}
  @close-drawer={onClose}
  x-cloak
>
  <AvDrawer title={title} description={description}>
    <div class="av-auth-stack-md av-drawer-body-scroll drawer-body-scroll">
      <slot />
    </div>

    <div slot="footer" class="av-auth-stack-sm av-drawer-footer-stack">
      <div class="av-drawer-footer-notice drawer-footer-notice">
        <slot name="notice" />
      </div>
      <div class="av-row-wrap av-drawer-footer-actions">
        <slot name="actions">
          <AvButton variant="ghost" type="button" @click={onClose}>Close</AvButton>
        </slot>
      </div>
    </div>
  </AvDrawer>
</div>
